# Normalize line endings: store everything as LF in the repo, regardless of
# the contributor's OS. Prevents noisy CRLF/LF diffs on Windows checkouts.
* text=auto eol=lf

# Explicitly treat known text types as text (LF in the repo).
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets — never normalize or diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
